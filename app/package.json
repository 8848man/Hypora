{
  "name": "hypora",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "oxlint",
    "preview": "vite preview",
    "verify:stage1": "tsx server/scripts/verifyStage1.ts",
    "verify:stage2": "tsx server/scripts/verifyStage2.ts",
    "verify:stage3": "tsx server/scripts/verifyStage3.ts",
    "verify:stage5": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs server/scripts/verifyStage5.ts",
    "verify:stage6": "tsx server/scripts/verifyStage6.ts",
    "verify:stage7": "tsx server/scripts/verifyStage7.ts",
    "verify:domain-summary": "tsx src/domain/verifySummaryLifecycle.ts",
    "verify:domain-navigation": "tsx src/domain/verifyNavigationState.ts"
  },
  "dependencies": {
    "@types/node": "^24.13.2",
    "firebase": "^12.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
