GEMINI_API_KEY=

# Analytics Platform Service (sdd/analytics/03_provider_independence.md).
# VITE_ prefix required for Vite to expose these to client code.
#
# Firestore is the Analytics Provider (source of truth, per ADR-0013) — set these
# three to activate it; leaving them unset activates the Noop Provider automatically.
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_APP_ID=
# Optional: Firestore collection path for events.
VITE_FIREBASE_EVENTS_COLLECTION=events

# GA4 is a separate, optional, non-portable reporting sink — never the Provider
# (see 03_provider_independence.md's GA4 carve-out). Set this in addition to the
# three above to also forward events to Firebase Analytics dashboards.
VITE_FIREBASE_MEASUREMENT_ID=
